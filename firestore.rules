rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'zexc66@gmail.com';
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.approved == true || isAdmin();
      allow create: if request.resource.data.approved == false
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.keys().hasAll(['reviewerName', 'rating', 'body']);
      allow update, delete: if isAdmin();
    }
  }
}
